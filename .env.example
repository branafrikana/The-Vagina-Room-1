# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# The password required to authenticate as an admin to edit text, images, and review form submissions.
ADMIN_PASSWORD="admin123"

# Firebase Project ID for database persistence
FIREBASE_PROJECT_ID="the-vagina-room"

# SMTP settings for Nodemailer
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Firebase Configuration as JSON string (Optional fallback for cloud systems like Render to avoid exposing keys in public git repositories)
# Expected Value: The complete JSON config object copied from your Firebase Project Settings -> Web App Setup
FIREBASE_CONFIG='{"apiKey": "...", "authDomain": "...", "projectId": "...", "storageBucket": "...", "messagingSenderId": "...", "appId": "...", "firestoreDatabaseId": "..."}'

# Payment provider keys
PAYSTACK_SECRET_KEY=""
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_PUBLIC_KEY=""

# Backend URL for static deployment
VITE_API_URL="http://localhost:3000"

# Cloudinary credentials for persistent media storage
# These are kept server-side only for security
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY="167779553977594"
CLOUDINARY_API_SECRET=""

# Public Cloudinary config for client-side helpers
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UPLOAD_PRESET="ml_default"

